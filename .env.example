# Copy this file to .env and fill in your own keys.
# The app works with OpenAI, Google Gemini, or both.

ENV=development

# LLM provider keys
OPENAI_API_KEY=api key
GOOGLE_API_KEY=api key


# Pick the default provider used when a request does not specify one.
DEFAULT_LLM_PROVIDER=openai

# Optional model overrides
OPENAI_MODEL=gpt-5.1
GEMINI_MODEL=gemini-3.1-flash-lite

# Model caching
CACHE_DIR=data/cache
CACHE_TTL_HOURS=24
MIN_HISTORY_YEARS=8
TEST_SIZE=0.15

# CORS: set to your deployed frontend URL in production.
ALLOWED_ORIGINS=*
